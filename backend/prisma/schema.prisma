// ─── CANDIDATE ASSESSMENT (External Invitations) ───

model Assessment {
  id                 String                   @id @default(uuid())
  orgId              String                   @map("org_id")
  title              String
  description        String?
  status             AssessmentStatus         @default(DRAFT)
  selectionMode      AssessmentSelectionMode  @default(MANUAL) @map("selection_mode")
  /// BLUEPRINT: {totalQuestions, domains:[{domain,percentage}], difficulty?, certificationId?}
  /// POOL:      {drawCount, certificationId?, difficulty?, categories?:[string], tags?:[string]}
  selectionConfig    Json?                    @map("selection_config")
  questionCount      Int                      @map("question_count")
  timeLimit          Int                      @map("time_limit")
  passingScore       Int?                     @map("passing_score")
  randomizeQuestions Boolean                  @default(true) @map("randomize_questions")
  randomizeChoices   Boolean                  @default(true) @map("randomize_choices")
  detectTabSwitch    Boolean                  @default(false) @map("detect_tab_switch")
  blockCopyPaste     Boolean                  @default(false) @map("block_copy_paste")
  requireFullscreen  Boolean                  @default(false) @map("require_fullscreen")
  requireOtp         Boolean                  @default(false) @map("require_otp")
  maxAttempts        Int                      @default(1)     @map("max_attempts")
  linkExpiryHours    Int                      @default(72) @map("link_expiry_hours")
  createdBy          String                   @map("created_by")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  organization     Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  candidateInvites CandidateInvite[]
  questions        AssessmentQuestion[]

  @@map("assessments")
}

model AssessmentQuestion {
  id               String  @id @default(uuid())
  assessmentId     String  @map("assessment_id")
  orgQuestionId    String? @map("org_question_id")
  publicQuestionId String? @map("public_question_id")
  sortOrder        Int     @default(0) @map("sort_order")

  assessment     Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  orgQuestion    OrgQuestion? @relation(fields: [orgQuestionId], references: [id])
  publicQuestion Question?    @relation(fields: [publicQuestionId], references: [id])

  @@map("assessment_questions")
}

model CandidateInvite {
  id             String                 @id @default(uuid())
  assessmentId   String                 @map("assessment_id")
  candidateEmail String                 @map("candidate_email")
  candidateName  String?                @map("candidate_name")
  token          String                 @unique
  status         CandidateAttemptStatus @default(INVITED)
  score          Decimal?               @db.Decimal(5, 2)
  totalCorrect   Int?                   @map("total_correct")
  totalQuestions Int?                   @map("total_questions")
  domainScores   Json?                  @map("domain_scores")
  timeSpent      Int?                   @map("time_spent")
  tabSwitchCount   Int?                   @map("tab_switch_count")
  ipAddress        String?                @map("ip_address")
  integrityScore   Int?                   @map("integrity_score")
  otpVerifiedAt    DateTime?              @map("otp_verified_at")
  startedAt        DateTime?              @map("started_at")
  submittedAt      DateTime?              @map("submitted_at")
  expiresAt        DateTime               @map("expires_at")
  /// POOL mode: snapshot of drawn OrgQuestion IDs for this invite (idempotent re-load)
  drawnQuestionIds String[]               @default([]) @map("drawn_question_ids")
  createdAt        DateTime               @default(now()) @map("created_at")

  assessment Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    CandidateAnswer[]
  events     CandidateEvent[]

  @@map("candidate_invites")
}

model CandidateAnswer {
  id              String   @id @default(uuid())
  inviteId        String   @map("invite_id")
  questionId      String   @map("question_id")
  selectedChoices String[] @map("selected_choices")
  isCorrect       Boolean? @map("is_correct")
  timeSpent       Int?     @map("time_spent")
  answeredAt      DateTime @default(now()) @map("answered_at")

  invite CandidateInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@map("candidate_answers")
}

model CandidateEvent {
  id        String   @id @default(uuid())
  inviteId  String   @map("invite_id")
  eventType String   @map("event_type")
  payload   Json     @default("{}")
  clientTs  DateTime @map("client_ts")
  createdAt DateTime @default(now()) @map("created_at")

  invite CandidateInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([inviteId, clientTs])
  @@map("candidate_events")
}

model AttemptEvent {
  id         String   @id @default(uuid())
  attemptId  String   @map("attempt_id")
  userId     String   @map("user_id")
  questionId String?  @map("question_id")
  eventType  String   @map("event_type")
  payload    Json
  clientTs   DateTime @map("client_ts")
  createdAt  DateTime @default(now()) @map("created_at")

  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@index([attemptId])
  @@index([userId, createdAt])
  @@map("attempt_events")
}

// RFC-003 (Sprint 4 US-401): Pass Predictor v0 output.
// Heuristic blends srsCoverage, recentAccuracy14d, domainSpread, timePressure.
// One row per (userId, certificationId); upserted by readiness:recompute job.
model ReadinessScore {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  certificationId String   @map("certification_id")
  score           Int // 0-100
  confidence      Decimal  @db.Decimal(4, 3) // 0.000-0.950
  attempts        Int      @default(0) // total attempts feeding this score
  signals         Json // { srsCoverage, recentAccuracy14d, domainSpread, timePressure }
  computedAt      DateTime @default(now()) @map("computed_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([userId, certificationId])
  @@index([certificationId, score])
  @@map("readiness_scores")
}

// RFC-012 v0 (Sprint 4 US-407): LLM cost ledger.
// One row per AI gen call. Used for per-org quota enforcement (warn-only this sprint).
model LlmUsageEvent {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  orgId        String?  @map("org_id")
  feature      String   // "question_generation" | "coach" | etc.
  modelId      String   @map("model_id")
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  costUsd      Decimal  @db.Decimal(10, 6) @map("cost_usd")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@map("llm_usage_events")
}

// US-408 — Pass-likelihood self-report survey for predictor validation.
// One response per user per certification; score is 1..10 (CHECK enforced in migration).
model PassLikelihoodSurvey {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  certificationId String   @map("certification_id")
  score           Int
  submittedAt     DateTime @default(now()) @map("submitted_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([userId, certificationId])
  @@index([certificationId])
  @@map("pass_likelihood_surveys")
}

// RFC-008 (Sprint 5 US-503): Behavioral Insights v0.
// Nightly job `insights:behavioral:nightly` reads `attempt_events` (last 14 days),
// computes per-user-per-cert patterns, upserts one row per (userId, certId, kind, generatedFor).
// `generated_for` is the calendar date (UTC) of the nightly run — provides idempotency
// and lets us re-run the job within a day without duplicating rows.
//
// `kind` is one of: "slow_on_long_stems" | "accuracy_decline_after_30min" | "domain_streak_break".
// New kinds can be added without a migration (string column).
//
// `payload` shape varies by kind. Examples:
//   slow_on_long_stems:        { avgMsLong: 92000, avgMsShort: 41000, delta: 0.18 }
//   accuracy_decline_after_30min: { firstWindow: 0.78, secondWindow: 0.62, drop: 0.16 }
//   domain_streak_break:       { domainId: "uuid", lastSeenAt: "2026-05-01T...", gapDays: 12 }
model BehavioralInsight {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  certificationId String   @map("certification_id")
  kind            String
  payload         Json
  evidenceCount   Int      @default(0) @map("evidence_count")
  generatedFor    DateTime @map("generated_for") @db.Date
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([userId, certificationId, kind, generatedFor])
  @@index([userId, generatedFor])
  @@index([certificationId, kind])
  @@map("behavioral_insights")
}

// ─── US-508: Reviewer Queue audit trail ───────────────────────────────────────

/// Immutable audit record for every Accept / Reject action in the Reviewer Queue.
model ModerationAudit {
  id         String           @id @default(uuid())
  questionId String           @map("question_id")
  reviewerId String           @map("reviewer_id")
  action     ModerationAction
  /// Required for REJECTED actions (≥ 10 chars); null for ACCEPTED.
  reason     String?
  createdAt  DateTime         @default(now()) @map("created_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reviewer User     @relation("ModerationAuditsReviewed", fields: [reviewerId], references: [id])

  @@index([questionId])
  @@index([reviewerId])
  @@map("moderation_audits")
}

// ─── Sprint 07: Scenario Engine & AI Coach ──────────────────────────────────────

// US-012a: Passage-based exam container.
// Scenario = a multi-question exam focused on a single passage + domain.
// Passage is markdown (200-400 words); diagram URL optional.
model Scenario {
  id               String   @id @default(uuid())
  examId           String?  @map("exam_id") // Optional: scenarios can exist independently or be part of an exam
  orgId            String   @map("org_id") // Organization that owns this scenario
  passageMarkdown  String   @db.Text // Markdown text, 200-400 words
  diagramUrl       String?  @map("diagram_url") // Optional diagram URL
  timeLimit        Int      @default(900) @map("time_limit") // seconds, default 15 min
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  exam      Exam?               @relation(fields: [examId], references: [id], onDelete: Cascade)
  org       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  questions ScenarioQuestion[]
  attempts  ScenarioAttempt[]

  @@index([examId])
  @@index([orgId])
  @@map("scenarios")
}

// US-012a: Junction model linking questions to scenarios.
// Preserves order of questions within a scenario via `order` field.
model ScenarioQuestion {
  id         String   @id @default(uuid())
  scenarioId String   @map("scenario_id")
  questionId String   @map("question_id")
  order      Int      @default(0) // 0-indexed position within scenario
  createdAt  DateTime @default(now()) @map("created_at")

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, questionId])
  @@index([scenarioId, order])
  @@index([questionId])
  @@map("scenario_questions")
}

// US-012a / US-012c: User attempt at a scenario exam.
// Tracks score, reasoning trace (explanation metadata), and completion time.
model ScenarioAttempt {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  scenarioId     String   @map("scenario_id")
  attemptedAt    DateTime @default(now()) @map("attempted_at")
  completedAt    DateTime? @map("completed_at") // null if in-progress
  score          Int?     @default(0) // 0-100; null if not yet scored
  reasoningTrace String?  @map("reasoning_trace") @db.Text // Explanation metadata from explanation generation

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([userId, scenarioId])
  @@index([userId, attemptedAt])
  @@index([scenarioId])
  @@map("scenario_attempts")
}

// US-603 (S6 carry-forward) / US-019: AI Coach multi-turn session.
// Stores conversation state (messages array), cost tracking, and session metadata.
// Indexed on (userId, createdAt) for rate limiting queries (e.g., count sessions in last hour).
model CoachSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  topic     String   @default("general") // certification domain or topic
  status    String   @default("active") // "active", "error", "completed"
  messages  Json     // Array of { role: "user" | "assistant", content: string, timestamp }
  costUsd   Decimal  @db.Decimal(10, 6) @default(0) @map("cost_usd") // LLM cost for this session
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("coach_sessions")
}

// US-015: Burnout detection via multi-signal analysis (exam score decline, question attempt patterns, time pressure).
// Indexed on (userId, detectedAt) for daily burnout checks and triggering coach interventions.
model BurnoutSignal {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  certificationId  String?  @map("certification_id")
  severity         String   @default("low") // "low", "medium", "high", "critical"
  signals          Json     // Array of { signal: "scoreDecline" | "timeAllocation" | "attemptFrequency" | "errorRate", score: float, metadata: {...} }
  recommendedAction String? @map("recommended_action") // e.g., "SUGGEST_BREAK", "SUGGEST_COACH", "ESCALATE"
  acknowledged     Boolean  @default(false)
  acknowledgedAt   DateTime? @map("acknowledged_at")
  detectedAt       DateTime @default(now()) @map("detected_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification? @relation(fields: [certificationId], references: [id], onDelete: SetNull)

  @@index([userId, detectedAt])
  @@index([userId, acknowledged])
  @@map("burnout_signals")
}

// US-807 / RFC-007: Vector embedding for semantic dedup + cross-cert knowledge graph.
// Raw `embedding vector(1536)` column is added via raw SQL migration (Prisma doesn't support pgvector natively).
model QuestionEmbedding {
  questionId String   @id @map("question_id")
  modelId    String   @map("model_id") // e.g. 'text-embedding-3-small'
  updatedAt  DateTime @updatedAt @map("updated_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_embeddings")
}

// US-017a: Cached cross-cert domain overlap scores.
// Populated by the overlap compute job; queried by GET /knowledge-graph/overlap.
model CertOverlap {
  id              String   @id @default(uuid())
  certAId         String   @map("cert_a_id")
  certBId         String   @map("cert_b_id")
  domainAId       String?  @map("domain_a_id")
  domainBId       String?  @map("domain_b_id")
  overlapPct      Float    @map("overlap_pct") // 0.0–1.0
  sharedTopics    Json     @default("[]") @map("shared_topics") // string[]
  computedAt      DateTime @default(now()) @map("computed_at")

  certA   Certification  @relation("CertOverlapA", fields: [certAId], references: [id], onDelete: Cascade)
  certB   Certification  @relation("CertOverlapB", fields: [certBId], references: [id], onDelete: Cascade)
  domainA Domain?        @relation("CertOverlapDomainA", fields: [domainAId], references: [id], onDelete: SetNull)
  domainB Domain?        @relation("CertOverlapDomainB", fields: [domainBId], references: [id], onDelete: SetNull)

  @@unique([certAId, certBId, domainAId, domainBId])
  @@index([certAId, computedAt])
  @@map("cert_overlaps")
}

// US-018 / RFC-010: DDS audit trail — each LLM-proposed distractor rewrite.
// Preserves full diff for review + rollback. Correctness invariant: correct answer never changes.
model QuestionVariant {
  id            String           @id @default(uuid())
  questionId    String           @map("question_id")
  variantOf     String?          @map("variant_of") // parent variant id for rollback chain
  rewriteJobId  String?          @map("rewrite_job_id")
  reason        DdsReason        @default(DDS_HARDEN)
  status        DdsVariantStatus @default(PENDING)
  diff          Json             // { originalChoices: Choice[], revisedChoices: Choice[] }
  reviewedBy    String?          @map("reviewed_by")
  reviewedAt    DateTime?        @map("reviewed_at")
  reviewNote    String?          @map("review_note")
  createdAt     DateTime         @default(now()) @map("created_at")

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reviewer   User?    @relation("QuestionVariantReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([questionId, status])
  @@index([createdAt])
  @@map("question_variants")
}

// US-020: Peer explanation submitted by a squad member for a question.
// Voted on by other squad members; top explanation earns the 'Top Explainer' badge.
model PeerExplanation {
  id          String   @id @default(uuid())
  questionId  String   @map("question_id")
  squadId     String   @map("squad_id")  // org_id of the squad
  authorId    String   @map("author_id")
  content     String   @db.Text
  upvotes     Int      @default(0)
  isTop       Boolean  @default(false) @map("is_top")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  question         Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  squad            Organization     @relation(fields: [squadId], references: [id], onDelete: Cascade)
  author           User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reputationFlags  ReputationFlag[]

  @@unique([questionId, squadId, authorId])
  @@index([questionId, squadId, upvotes])
  @@index([squadId, createdAt])
  @@map("peer_explanations")
}

// US-1002 (Sprint 10): Persisted study plan generated from Knowledge Graph overlap.
// One row per generation; users may regenerate (creates a new row).
model StudyPlan {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  targetCertId       String   @map("target_cert_id")
  sourceCertIds      String[] @map("source_cert_ids")
  skipTopics         Json     @map("skip_topics")
  mustLearnTopics    Json     @map("must_learn_topics")
  effortReductionPct Int      @map("effort_reduction_pct")
  totalTopics        Int      @map("total_topics")
  skippableCount     Int      @map("skippable_count")
  createdAt          DateTime @default(now()) @map("created_at")

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetCert Certification @relation(fields: [targetCertId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, targetCertId])
  @@map("study_plans")
}

// US-1005 (Sprint 10): Accumulated reputation points per user per squad.
// Points incremented on explanation upvotes/promotions; idempotent via Vote id.
model UserReputation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  squadId   String   @map("squad_id")
  points    Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  squad Organization @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@unique([userId, squadId])
  @@index([squadId, points])
  @@map("user_reputations")
}

// US-1102 (Sprint 11): Anti-gaming flag for suspicious votes.
// When a vote is detected as velocity_burst or vote_ring, points are not accrued
// and a flag is created for admin review. Admin can clear (legit) or confirm (abuse).
model ReputationFlag {
  id            String    @id @default(uuid())
  flaggedUserId String    @map("flagged_user_id")
  voterId       String    @map("voter_id")
  explanationId String    @map("explanation_id")
  squadId       String    @map("squad_id")
  reason        String
  pointsHeld    Int       @map("points_held")
  status        String    @default("pending")
  createdAt     DateTime  @default(now()) @map("created_at")
  resolvedAt    DateTime? @map("resolved_at")

  flaggedUser User            @relation("FlaggedUser", fields: [flaggedUserId], references: [id], onDelete: Cascade)
  voter       User            @relation("FlagVoter",   fields: [voterId],       references: [id], onDelete: Cascade)
  explanation PeerExplanation @relation(fields: [explanationId], references: [id], onDelete: Cascade)
  squad       Organization    @relation(fields: [squadId],       references: [id], onDelete: Cascade)

  @@index([squadId, status])
  @@index([flaggedUserId, createdAt])
  @@map("reputation_flags")
}

// US-1101 (Sprint 11): DDS auto-apply config per cohort.
// Tracks shadow mode state (live vs shadow) and canary monitoring for each cohort.
// Default cohort starts in shadow mode; can be promoted to live after Gate 2 approval.
model DdsConfig {
  id                  String    @id @default(uuid())
  cohortName          String    @unique @map("cohort_name")
  shadowModeEnabled   Boolean   @default(true) @map("shadow_mode_enabled")
  canaryArmed         Boolean   @default(false) @map("canary_armed")
  promotedAt          DateTime? @map("promoted_at")
  promotedBy          String?   @map("promoted_by") // userId of admin who flipped
  canaryPausedAt      DateTime? @map("canary_paused_at")
  canaryAutoResumeAt  DateTime? @map("canary_auto_resume_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  promoter User? @relation(fields: [promotedBy], references: [id], onDelete: SetNull)

  @@index([cohortName])
  @@map("dds_configs")
}

