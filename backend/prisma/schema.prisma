  groups           OrgGroup[]
  privateQuestions OrgQuestion[]
  catalogItems     ExamCatalogItem[]
  assessments      Assessment[]
  joinLinks        OrgJoinLink[]
  learningTracks   LearningTrack[]
  generationJobs   QuestionGenerationJob[] // RFC-012: Track org-level LLM costs
  scenarios        Scenario[]
  certification    Certification? @relation("SquadCertification", fields: [certificationId], references: [id])
  peerExplanations PeerExplanation[]
  userReputations  UserReputation[]
  reputationFlags  ReputationFlag[]

  @@map("organizations")
}

model OrgMember {
