generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  LEARNER
  CONTRIBUTOR
  REVIEWER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum UserPlan {
  FREE
  PREMIUM
  ENTERPRISE
}

enum QuestionType {
  SINGLE
  MULTIPLE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ExamVisibility {
  PUBLIC
  PRIVATE
  LINK
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
}

enum VoteTargetType {
  QUESTION
  COMMENT
}

enum ReportReason {
  WRONG_ANSWER
  OUTDATED
  DUPLICATE
  INAPPROPRIATE
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum MistakeType {
  CONCEPT
  CARELESS
  TRAP
  TIME_PRESSURE
}

enum FlashcardSource {
  MANUAL
  EXAM_CAPTURE
}

enum TimerMode {
  STRICT
  ACCELERATED
  RELAXED
  TIME_PRESSURE
}

enum ExamType {
  STANDARD
  TIME_PRESSURE
}

enum FlashcardMastery {
  NEW
  LEARNING
  REVIEW
  MASTERED
}

enum LlmProvider {
  OPENAI
  ANTHROPIC
  GEMINI
}

enum GenerationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum QualityTier {
  HIGH
  MEDIUM
  LOW
}

enum MaterialContentType {
  PDF
  URL
  TEXT
}

// ==================== ENTERPRISE ENUMS ====================

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

enum OrgInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AssessmentStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum CandidateAttemptStatus {
  INVITED
  STARTED
  SUBMITTED
  EXPIRED
}

enum ExamCatalogItemType {
  FIXED
  DYNAMIC
}

enum OrgQuestionStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// ==================== MODELS ====================

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  passwordHash   String     @map("password_hash")
  displayName    String     @map("display_name")
  avatarUrl      String?    @map("avatar_url")
  role           UserRole   @default(LEARNER)
  status         UserStatus @default(ACTIVE)
  plan           UserPlan   @default(FREE)
  points         Int        @default(0)
  suspendedUntil DateTime?  @map("suspended_until")
  banReason      String?    @map("ban_reason")
  featureFlags   Json       @default("{}") @map("feature_flags")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  questions    Question[]
  examAttempts ExamAttempt[]
  exams        Exam[]
  comments     Comment[]
  votes        Vote[]
  reports      Report[]
  badgeAwards  BadgeAward[]
  reviewSchedules ReviewSchedule[]
  decks                      Deck[]
  flashcardReviewSchedules   FlashcardReviewSchedule[]
  capturedWords              CapturedWord[]
  llmConfigs                 UserLlmConfig[]
  generationJobs             QuestionGenerationJob[]
  sourceMaterials            SourceMaterial[]
  auditLogs                  AuditLog[]
  orgMemberships             OrgMember[]
  attemptEvents              AttemptEvent[]
  readinessScores            ReadinessScore[]
  llmUsageEvents             LlmUsageEvent[]
  passLikelihoodSurveys      PassLikelihoodSurvey[]

  @@index([status])
  @@map("users")
}

model Provider {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  logoUrl     String?  @map("logo_url")
  website     String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  certifications Certification[]

  @@map("providers")
}

model Certification {
  id          String   @id @default(uuid())
  name        String
  providerId  String   @map("provider_id")
  code        String   @unique
  description String?
  examFormat  Json?    @map("exam_format")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  provider       Provider @relation(fields: [providerId], references: [id])
  domains        Domain[]
  questions      Question[]
  exams          Exam[]
  tags           Tag[]
  decks          Deck[]
  generationJobs QuestionGenerationJob[]
  sourceMaterials SourceMaterial[]
  catalogItems   ExamCatalogItem[]
  orgQuestions   OrgQuestion[]
  readinessScores ReadinessScore[]
  passLikelihoodSurveys PassLikelihoodSurvey[]

  @@map("certifications")
}

model Domain {
  id              String        @id @default(uuid())
  certificationId String        @map("certification_id")
  name            String
  weight          Decimal?      @db.Decimal(5, 2)
  description     String?

  certification  Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  questions      Question[]
  generationJobs QuestionGenerationJob[]

  @@map("domains")
}

model Question {
  id              String         @id @default(uuid())
  certificationId String         @map("certification_id")
  domainId        String?        @map("domain_id")
  createdBy       String         @map("created_by")
  title           String
  description     String?
  questionType    QuestionType   @default(SINGLE) @map("question_type")
  difficulty      Difficulty     @default(MEDIUM)
  explanation     String?
  referenceUrl    String?        @map("reference_url")
  codeSnippet     String?        @map("code_snippet")
  imageUrl        String?        @map("image_url")
  isScenario      Boolean        @default(false) @map("is_scenario")
  isTrapQuestion  Boolean        @default(false) @map("is_trap_question")
  status          QuestionStatus @default(DRAFT)
  upvotes         Int            @default(0)
  downvotes       Int            @default(0)
  attemptCount    Int            @default(0) @map("attempt_count")
  correctCount    Int            @default(0) @map("correct_count")
  isAiGenerated   Boolean        @default(false) @map("is_ai_generated")
  generationJobId String?        @map("generation_job_id")
  qualityTier     QualityTier?   @map("quality_tier")
  sourceChunkId   String?        @map("source_chunk_id")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  certification   Certification   @relation(fields: [certificationId], references: [id])
  domain          Domain?         @relation(fields: [domainId], references: [id])
  author          User            @relation(fields: [createdBy], references: [id])
  generationJob   QuestionGenerationJob? @relation(fields: [generationJobId], references: [id])
  sourceChunk     SourceChunk?    @relation(fields: [sourceChunkId], references: [id])
  choices         Choice[]
  tags            QuestionTag[]
  examQuestions   ExamQuestion[]
  answers         Answer[]
  comments        Comment[]
  votes           Vote[]
  reports         Report[]
  reviewSchedules ReviewSchedule[]
  capturedWords   CapturedWord[]
  catalogLinks    ExamCatalogQuestion[]
  assessmentLinks AssessmentQuestion[]

  @@index([deletedAt])
  @@index([status])
  @@index([certificationId, status])
  @@map("questions")
}

model Choice {
  id         String  @id @default(uuid())
  questionId String  @map("question_id")
  label      String  @db.Char(1)
  content    String
  isCorrect  Boolean @default(false) @map("is_correct")
  sortOrder  Int     @default(0) @map("sort_order")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("choices")
}

model Tag {
  id              String  @id @default(uuid())
  name            String
  certificationId String? @map("certification_id")

  certification Certification? @relation(fields: [certificationId], references: [id])
  questions     QuestionTag[]

  @@unique([name, certificationId])
  @@map("tags")
}

model QuestionTag {
  questionId String @map("question_id")
  tagId      String @map("tag_id")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@map("question_tags")
}

model Exam {
  id              String         @id @default(uuid())
  createdBy       String         @map("created_by")
  certificationId String         @map("certification_id")
  title           String
  description     String?
  questionCount   Int            @map("question_count")
  timeLimit       Int            @map("time_limit")
  difficultyDist  Json?          @map("difficulty_dist")
  visibility      ExamVisibility @default(PUBLIC)
  shareCode       String?        @unique @map("share_code")
  isAdaptive      Boolean        @default(false) @map("is_adaptive")
  timerMode       TimerMode      @default(STRICT) @map("timer_mode")
  attemptCount    Int            @default(0) @map("attempt_count")
  avgScore        Decimal?       @map("avg_score") @db.Decimal(5, 2)
  createdAt       DateTime       @default(now()) @map("created_at")

  author        User           @relation(fields: [createdBy], references: [id])
  certification Certification  @relation(fields: [certificationId], references: [id])
  examQuestions ExamQuestion[]
  attempts      ExamAttempt[]

  @@map("exams")
}

model ExamQuestion {
  examId     String @map("exam_id")
  questionId String @map("question_id")
  sortOrder  Int    @default(0) @map("sort_order")

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@id([examId, questionId])
  @@map("exam_questions")
}

model ExamAttempt {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  examId         String        @map("exam_id")
  startedAt      DateTime      @default(now()) @map("started_at")
  submittedAt    DateTime?     @map("submitted_at")
  timeSpent      Int?          @map("time_spent")
  score          Decimal?      @db.Decimal(5, 2)
  totalCorrect   Int?          @map("total_correct")
  totalQuestions Int?          @map("total_questions")
  domainScores   Json?         @map("domain_scores")
  examType       ExamType      @default(STANDARD) @map("exam_type")
  status         AttemptStatus @default(IN_PROGRESS)

  user    User     @relation(fields: [userId], references: [id])
  exam    Exam     @relation(fields: [examId], references: [id])
  answers Answer[]
  capturedWords  CapturedWord[]
  attemptEvents  AttemptEvent[]

  @@map("exam_attempts")
}

model Answer {
  id              String   @id @default(uuid())
  attemptId       String   @map("attempt_id")
  questionId      String   @map("question_id")
  selectedChoices String[] @map("selected_choices")
  isCorrect       Boolean? @map("is_correct")
  isMarked        Boolean  @default(false) @map("is_marked")
  timeSpent       Int?     @map("time_spent")
  answeredAt      DateTime @default(now()) @map("answered_at")
  mistakeType     MistakeType? @map("mistake_type")

  attempt  ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@map("answers")
}

model Comment {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  questionId String   @map("question_id")
  parentId   String?  @map("parent_id")
  content    String
  upvotes    Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id])
  question Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@map("comments")
}

model Vote {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  targetType VoteTargetType @map("target_type")
  targetId   String         @map("target_id")
  value      Int            @db.SmallInt
  createdAt  DateTime       @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id])
  question Question? @relation(fields: [targetId], references: [id])

  @@unique([userId, targetType, targetId])
  @@map("votes")
}

model Report {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  questionId  String       @map("question_id")
  reason      ReportReason
  description String?
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])

  @@map("reports")
}

model Badge {
  id          String @id @default(uuid())
  name        String
  description String?
  iconUrl     String? @map("icon_url")
  criteria    Json?

  awards BadgeAward[]

  @@map("badges")
}

model BadgeAward {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  awardedAt DateTime @default(now()) @map("awarded_at")

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("badge_awards")
}

model ReviewSchedule {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  questionId     String           @map("question_id")
  nextReviewDate DateTime         @map("next_review_date")
  intervalDays   Int              @default(0) @map("interval_days")
  easeFactor     Decimal          @default(2.50) @map("ease_factor") @db.Decimal(4, 2)
  repetitions    Int              @default(0)
  mastery        FlashcardMastery @default(NEW)
  lastQuality    Int?             @map("last_quality")
  lapses         Int              @default(0)
  lastReviewedAt DateTime?        @map("last_reviewed_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextReviewDate])
  @@map("review_schedules")
}

model Deck {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  description     String?
  certificationId String?  @map("certification_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification? @relation(fields: [certificationId], references: [id])
  flashcards    Flashcard[]

  @@map("decks")
}

model Flashcard {
  id        String          @id @default(uuid())
  deckId    String          @map("deck_id")
  front     String
  back      String
  hint      String?
  tags      String[]        @default([])
  source    FlashcardSource @default(MANUAL)
  isStarred Boolean         @default(false) @map("is_starred")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  deck     Deck                      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  schedule FlashcardReviewSchedule?

  @@map("flashcards")
}

model FlashcardReviewSchedule {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  flashcardId    String           @unique @map("flashcard_id")
  nextReviewDate DateTime         @map("next_review_date")
  intervalDays   Int              @default(0) @map("interval_days")
  easeFactor     Decimal          @default(2.50) @map("ease_factor") @db.Decimal(4, 2)
  repetitions    Int              @default(0)
  lapses         Int              @default(0)
  mastery        FlashcardMastery @default(NEW)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
  @@index([userId, nextReviewDate])
  @@index([userId, mastery])
  @@map("flashcard_review_schedules")
}

model CapturedWord {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  word            String
  context         String?
  examAttemptId   String?  @map("exam_attempt_id")
  questionId      String?  @map("question_id")
  status          String   @default("pending")
  createdAt       DateTime @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  examAttempt ExamAttempt? @relation(fields: [examAttemptId], references: [id])
  question    Question?    @relation(fields: [questionId], references: [id])

  @@map("captured_words")
}

// ==================== AI QUESTION BANK ====================

model UserLlmConfig {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  provider     LlmProvider
  encryptedKey String      @map("encrypted_key")
  modelId      String?     @map("model_id")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_llm_configs")
}

model SourceMaterial {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  certificationId String?             @map("certification_id")
  title           String
  originalFilename String?            @map("original_filename")
  contentType     MaterialContentType @map("content_type")
  sourceUrl       String?             @map("source_url")
  chunkCount      Int                 @default(0) @map("chunk_count")
  status          String              @default("processing")
  createdAt       DateTime            @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification? @relation(fields: [certificationId], references: [id])
  chunks        SourceChunk[]
  generationJobs QuestionGenerationJob[]

  @@map("source_materials")
}

model SourceChunk {
  id           String   @id @default(uuid())
  materialId   String   @map("material_id")
  content      String
  chunkIndex   Int      @map("chunk_index")
  pageNumber   Int?     @map("page_number")
  sectionTitle String?  @map("section_title")
  tokenCount   Int?     @map("token_count")
  createdAt    DateTime @default(now()) @map("created_at")

  material   SourceMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  questions  Question[]

  @@map("source_chunks")
}

model QuestionGenerationJob {
  id               String              @id @default(uuid())
  userId           String              @map("user_id")
  orgId            String?             @map("org_id") // RFC-012: Track org for cost attribution
  certificationId  String              @map("certification_id")
  domainId         String?             @map("domain_id")
  materialId       String?             @map("material_id")
  provider         LlmProvider
  modelId          String?             @map("model_id")
  difficulty       Difficulty
  questionCount    Int                 @map("question_count")
  status           GenerationJobStatus @default(PENDING)
  promptTokens     Int?                @map("prompt_tokens")
  completionTokens Int?                @map("completion_tokens")
  qualityScores    Json?               @map("quality_scores")
  previewData      Json?               @map("preview_data")
  errorMessage     String?             @map("error_message")
  createdAt        DateTime            @default(now()) @map("created_at")
  completedAt      DateTime?           @map("completed_at")

  user          User                @relation(fields: [userId], references: [id])
  organization  Organization?       @relation(fields: [orgId], references: [id])
  certification Certification       @relation(fields: [certificationId], references: [id])
  domain        Domain?             @relation(fields: [domainId], references: [id])
  material      SourceMaterial?     @relation(fields: [materialId], references: [id])
  questions     Question[]

  @@map("question_generation_jobs")
}

// ==================== ADMIN ====================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== ENTERPRISE ====================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?  @map("logo_url")
  description String?
  industry    String?
  accentColor String?  @map("accent_color")
  maxSeats    Int      @default(10) @map("max_seats")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members          OrgMember[]
  invites          OrgInvite[]
  groups           OrgGroup[]
  privateQuestions OrgQuestion[]
  catalogItems     ExamCatalogItem[]
  assessments      Assessment[]
  joinLinks        OrgJoinLink[]
  learningTracks   LearningTrack[]
  generationJobs   QuestionGenerationJob[] // RFC-012: Track org-level LLM costs

  @@map("organizations")
}

model OrgMember {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  role      OrgRole  @default(MEMBER)
  groupId   String?  @map("group_id")
  joinedAt  DateTime @default(now()) @map("joined_at")
  isActive  Boolean  @default(true) @map("is_active")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  group        OrgGroup?    @relation(fields: [groupId], references: [id])

  @@unique([orgId, userId])
  @@map("org_members")
}

model OrgGroup {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members      OrgMember[]
  assignments  OrgExamAssignment[]

  @@map("org_groups")
}

model OrgInvite {
  id        String          @id @default(uuid())
  orgId     String          @map("org_id")
  email     String
  role      OrgRole         @default(MEMBER)
  token     String          @unique
  status    OrgInviteStatus @default(PENDING)
  invitedBy String          @map("invited_by")
  expiresAt DateTime        @map("expires_at")
  createdAt DateTime        @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_invites")
}

model OrgJoinLink {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  code        String    @unique
  maxUses     Int?      @map("max_uses")
  currentUses Int       @default(0) @map("current_uses")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_join_links")
}

model OrgQuestion {
  id               String            @id @default(uuid())
  orgId            String            @map("org_id")
  createdBy        String            @map("created_by")
  sourceQuestionId String?           @map("source_question_id")
  title            String
  description      String?
  questionType     QuestionType      @default(SINGLE) @map("question_type")
  difficulty       Difficulty        @default(MEDIUM)
  explanation      String?
  referenceUrl     String?           @map("reference_url")
  codeSnippet      String?           @map("code_snippet")
  isScenario       Boolean           @default(false) @map("is_scenario")
  isTrapQuestion   Boolean           @default(false) @map("is_trap_question")
  status           OrgQuestionStatus @default(DRAFT)
  category         String?
  tags             String[]          @default([])
  certificationId  String?           @map("certification_id")
  version          Int               @default(1)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  organization    Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  certification   Certification?        @relation(fields: [certificationId], references: [id])
  choices         OrgQuestionChoice[]
  catalogLinks    ExamCatalogQuestion[]
  assessmentLinks AssessmentQuestion[]

  @@index([orgId, status])
  @@map("org_questions")
}

model OrgQuestionChoice {
  id            String  @id @default(uuid())
  orgQuestionId String  @map("org_question_id")
  label         String  @db.Char(1)
  content       String
  isCorrect     Boolean @default(false) @map("is_correct")
  sortOrder     Int     @default(0) @map("sort_order")

  orgQuestion OrgQuestion @relation(fields: [orgQuestionId], references: [id], onDelete: Cascade)

  @@map("org_question_choices")
}

model ExamCatalogItem {
  id              String              @id @default(uuid())
  orgId           String              @map("org_id")
  title           String
  description     String?
  type            ExamCatalogItemType @default(FIXED)
  certificationId String?             @map("certification_id")
  questionCount   Int                 @map("question_count")
  timeLimit       Int                 @map("time_limit")
  passingScore    Int?                @map("passing_score")
  timerMode       TimerMode           @default(STRICT) @map("timer_mode")
  maxAttempts     Int?                @map("max_attempts")
  availableFrom   DateTime?           @map("available_from")
  availableUntil  DateTime?           @map("available_until")
  isMandatory     Boolean             @default(false) @map("is_mandatory")
  sortOrder       Int                 @default(0) @map("sort_order")
  trackId         String?             @map("track_id")
  prerequisiteId  String?             @map("prerequisite_id")
  createdBy       String              @map("created_by")
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  organization  Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  certification Certification?       @relation(fields: [certificationId], references: [id])
  prerequisite  ExamCatalogItem?     @relation("Prerequisites", fields: [prerequisiteId], references: [id])
  dependents    ExamCatalogItem[]    @relation("Prerequisites")
  questions     ExamCatalogQuestion[]
  assignments   OrgExamAssignment[]
  track         LearningTrack?       @relation(fields: [trackId], references: [id])

  @@map("exam_catalog_items")
}

model ExamCatalogQuestion {
  id               String  @id @default(uuid())
  catalogItemId    String  @map("catalog_item_id")
  orgQuestionId    String? @map("org_question_id")
  publicQuestionId String? @map("public_question_id")
  sortOrder        Int     @default(0) @map("sort_order")

  catalogItem    ExamCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  orgQuestion    OrgQuestion?    @relation(fields: [orgQuestionId], references: [id])
  publicQuestion Question?       @relation(fields: [publicQuestionId], references: [id])

  @@map("exam_catalog_questions")
}

model LearningTrack {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  catalogItems ExamCatalogItem[]

  @@map("learning_tracks")
}

model OrgExamAssignment {
  id            String    @id @default(uuid())
  catalogItemId String    @map("catalog_item_id")
  groupId       String?   @map("group_id")
  memberId      String?   @map("member_id")
  dueDate       DateTime? @map("due_date")
  assignedAt    DateTime  @default(now()) @map("assigned_at")

  catalogItem ExamCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  group       OrgGroup?       @relation(fields: [groupId], references: [id])

  @@map("org_exam_assignments")
}

// ─── CANDIDATE ASSESSMENT (External Invitations) ───

model Assessment {
  id                 String           @id @default(uuid())
  orgId              String           @map("org_id")
  title              String
  description        String?
  status             AssessmentStatus @default(DRAFT)
  questionCount      Int              @map("question_count")
  timeLimit          Int              @map("time_limit")
  passingScore       Int?             @map("passing_score")
  randomizeQuestions Boolean          @default(true) @map("randomize_questions")
  randomizeChoices   Boolean          @default(true) @map("randomize_choices")
  detectTabSwitch    Boolean          @default(false) @map("detect_tab_switch")
  blockCopyPaste     Boolean          @default(false) @map("block_copy_paste")
  linkExpiryHours    Int              @default(72) @map("link_expiry_hours")
  createdBy          String           @map("created_by")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  organization     Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  candidateInvites CandidateInvite[]
  questions        AssessmentQuestion[]

  @@map("assessments")
}

model AssessmentQuestion {
  id               String  @id @default(uuid())
  assessmentId     String  @map("assessment_id")
  orgQuestionId    String? @map("org_question_id")
  publicQuestionId String? @map("public_question_id")
  sortOrder        Int     @default(0) @map("sort_order")

  assessment     Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  orgQuestion    OrgQuestion? @relation(fields: [orgQuestionId], references: [id])
  publicQuestion Question?    @relation(fields: [publicQuestionId], references: [id])

  @@map("assessment_questions")
}

model CandidateInvite {
  id             String                 @id @default(uuid())
  assessmentId   String                 @map("assessment_id")
  candidateEmail String                 @map("candidate_email")
  candidateName  String?                @map("candidate_name")
  token          String                 @unique
  status         CandidateAttemptStatus @default(INVITED)
  score          Decimal?               @db.Decimal(5, 2)
  totalCorrect   Int?                   @map("total_correct")
  totalQuestions Int?                   @map("total_questions")
  domainScores   Json?                  @map("domain_scores")
  timeSpent      Int?                   @map("time_spent")
  tabSwitchCount Int?                   @map("tab_switch_count")
  ipAddress      String?                @map("ip_address")
  startedAt      DateTime?              @map("started_at")
  submittedAt    DateTime?              @map("submitted_at")
  expiresAt      DateTime               @map("expires_at")
  createdAt      DateTime               @default(now()) @map("created_at")

  assessment Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    CandidateAnswer[]

  @@map("candidate_invites")
}

model CandidateAnswer {
  id              String   @id @default(uuid())
  inviteId        String   @map("invite_id")
  questionId      String   @map("question_id")
  selectedChoices String[] @map("selected_choices")
  isCorrect       Boolean? @map("is_correct")
  timeSpent       Int?     @map("time_spent")
  answeredAt      DateTime @default(now()) @map("answered_at")

  invite CandidateInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@map("candidate_answers")
}

model AttemptEvent {
  id         String   @id @default(uuid())
  attemptId  String   @map("attempt_id")
  userId     String   @map("user_id")
  questionId String?  @map("question_id")
  eventType  String   @map("event_type")
  payload    Json
  clientTs   DateTime @map("client_ts")
  createdAt  DateTime @default(now()) @map("created_at")

  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@index([attemptId])
  @@index([userId, createdAt])
  @@map("attempt_events")
}

// RFC-003 (Sprint 4 US-401): Pass Predictor v0 output.
// Heuristic blends srsCoverage, recentAccuracy14d, domainSpread, timePressure.
// One row per (userId, certificationId); upserted by readiness:recompute job.
model ReadinessScore {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  certificationId String   @map("certification_id")
  score           Int // 0-100
  confidence      Decimal  @db.Decimal(4, 3) // 0.000-0.950
  attempts        Int      @default(0) // total attempts feeding this score
  signals         Json // { srsCoverage, recentAccuracy14d, domainSpread, timePressure }
  computedAt      DateTime @default(now()) @map("computed_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([userId, certificationId])
  @@index([certificationId, score])
  @@map("readiness_scores")
}

// RFC-012 v0 (Sprint 4 US-407): LLM cost ledger.
// One row per AI gen call. Used for per-org quota enforcement (warn-only this sprint).
model LlmUsageEvent {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  orgId        String?  @map("org_id")
  feature      String   // "question_generation" | "coach" | etc.
  modelId      String   @map("model_id")
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  costUsd      Decimal  @db.Decimal(10, 6) @map("cost_usd")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@map("llm_usage_events")
}

// US-408 — Pass-likelihood self-report survey for predictor validation.
// One response per user per certification; score is 1..10 (CHECK enforced in migration).
model PassLikelihoodSurvey {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  certificationId String   @map("certification_id")
  score           Int
  submittedAt     DateTime @default(now()) @map("submitted_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([userId, certificationId])
  @@index([certificationId])
  @@map("pass_likelihood_surveys")
}
