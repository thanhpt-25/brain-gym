# E2E Test Database Configuration
# This file is loaded by Prisma when NODE_ENV=test
# It overrides .env settings for testing
#
# For local testing: change password to match your local PostgreSQL setup
# For CI testing: the CI workflow sets DATABASE_URL env var with braingym_ci_test password

DATABASE_URL="postgresql://braingym:braingym_ci_test@localhost:5432/braingym_test?schema=public"

# These can stay the same for testing
JWT_SECRET="test-jwt-secret-do-not-use-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="test-refresh-secret-do-not-use-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# App
PORT=3000
NODE_ENV=test

# LLM Encryption Secret (test value, 32 chars minimum)
LLM_KEY_ENCRYPTION_SECRET="test-llm-encryption-secret-32chr"
