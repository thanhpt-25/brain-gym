# Database
DATABASE_URL="postgresql://braingym:CHANGE_ME@localhost:5432/braingym?schema=public"

# JWT — generate with: openssl rand -base64 32
JWT_SECRET="CHANGE_ME"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_ME"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# App
PORT=3000
NODE_ENV=development

# AI Question Bank — Key Encryption (generate with: openssl rand -hex 32)
# Must be at least 32 characters. Change this in production!
LLM_KEY_ENCRYPTION_SECRET="CHANGE_ME_generate_with_openssl_rand_hex_32"

# LLM Quota — Warn-only quota for org daily spending (RFC-012)
# When org's daily LLM spend exceeds this limit, a warning is logged (non-blocking)
# Default: $5/day
LLM_DAILY_QUOTA_USD="5"

# OAuth Providers
# Google: create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
