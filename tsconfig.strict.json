{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true
  },
  "include": [
    "src/vite-env.d.ts",
    "src/services/**/*",
    "src/stores/auth.store.ts"
  ],
  "exclude": ["node_modules"]
}
